﻿@using MathUniverse.Models
@model List<Notification>

<div class="notification-bell-container">
    <div class="dropdown">
         <button class="btn btn-link position-relative notification-bell-btn" type="button" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Thông báo">
            <i class="fas fa-bell fa-lg"></i>
            @if ((int)(ViewBag.UnreadCount ?? 0) > 0)
            {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger notification-badge">
                    @(((int)ViewBag.UnreadCount > 9) ? "9+" : ViewBag.UnreadCount.ToString())
                </span>
            }
        </button>
        
        <div class="dropdown-menu dropdown-menu-end notification-dropdown" aria-labelledby="notificationDropdown">
            <div class="notification-header">
                <h6 class="mb-0">
                    <i class="fas fa-bell"></i> Thông báo
                </h6>
                @if ((int)(ViewBag.UnreadCount ?? 0) > 0)
                {
                    <button class="btn btn-sm btn-link mark-all-read" type="button" onclick="markAllAsRead(event)">
                        <i class="fas fa-check-double"></i> Đánh dấu đã đọc
                    </button>
                }
            </div>
            
            <div class="notification-list">
                @if (Model != null && Model.Any())
                {
                    foreach (var notification in Model)
                    {
                        <a href="@(notification.LinkUrl ?? "#")" class="notification-item @(!notification.IsRead ? "unread" : "")" data-id="@notification.NotificationId" onclick="markAsRead(event, @notification.NotificationId)">
                            <div class="notification-icon @GetNotificationIconClass(notification.Type)">
                                <i class="@GetNotificationIcon(notification.Type)"></i>
                            </div>
                            <div class="notification-content">
                                <div class="notification-title">@notification.Title</div>
                                <div class="notification-message">@notification.Message</div>
                                <div class="notification-time">
                                    <i class="far fa-clock"></i> @GetTimeAgo(notification.CreatedDate)
                                </div>
                            </div>
                            @if (!notification.IsRead)
                            {
                                <div class="notification-unread-dot"></div>
                            }
                        </a>
                    }
                }
                else
                {
                    <div class="notification-empty">
                        <i class="fas fa-inbox fa-3x mb-3"></i>
                        <p>Chưa có thông báo nào</p>
                    </div>
                }
            </div>
            
            @if (Model != null && Model.Any())
            {
                <div class="notification-footer">
                    <a asp-controller="Student" asp-action="Notifications" class="btn btn-sm btn-link w-100">
                        Xem tất cả thông báo
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    /* Wrapper to ensure dropdown aligns nicely */
    .notification-bell-container {
        display: flex;
        align-items: center;
    }

    .notification-bell-btn {
        color: #fff;
        padding: 0.5rem;
        border: none;
        background: none;
        transition: all 0.3s ease;
    }

    .notification-bell-btn:hover {
        transform: scale(1.1);
        color: #fbbf24;
    }

    .notification-badge {
        font-size: 0.65rem;
        padding: 0.25rem 0.4rem;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }

    .notification-dropdown {
        width: 380px;
        max-height: 600px;
        border: none;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        border-radius: 15px;
        padding: 0;
        margin-top: 0.5rem;
    }

    .notification-header {
        padding: 1rem 1.25rem;
        border-bottom: 2px solid #e5e7eb;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 15px 15px 0 0;
    }

    .notification-header h6 {
        color: #fff;
        font-weight: 700;
    }

    .mark-all-read {
        color: #fff !important;
        font-size: 0.85rem;
        text-decoration: none;
        padding: 0.25rem 0.5rem;
    }

    .mark-all-read:hover {
        text-decoration: underline;
    }

    .notification-list {
        max-height: 400px;
        overflow-y: auto;
        padding: 0.5rem 0;
    }

    .notification-item {
        display: flex;
        align-items: start;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f3f4f6;
        text-decoration: none;
        color: inherit;
        transition: all 0.3s ease;
        position: relative;
    }

    .notification-item:hover {
        background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
    }

    .notification-item.unread {
        background: #f0f9ff;
    }

    .notification-icon {
        width: 45px;
        height: 45px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 1rem;
        flex-shrink: 0;
        font-size: 1.2rem;
    }

    .icon-achievement {
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: #fff;
    }

    .icon-reminder {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: #fff;
    }

    .icon-new {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: #fff;
    }

    .icon-report {
        background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
        color: #fff;
    }

    .icon-system {
        background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
        color: #fff;
    }

    .notification-content {
        flex: 1;
    }

    .notification-title {
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 0.25rem;
        font-size: 0.95rem;
    }

    .notification-message {
        color: #6b7280;
        font-size: 0.875rem;
        line-height: 1.4;
        margin-bottom: 0.5rem;
    }

    .notification-time {
        font-size: 0.75rem;
        color: #9ca3af;
    }

    .notification-unread-dot {
        width: 10px;
        height: 10px;
        background: #3b82f6;
        border-radius: 50%;
        position: absolute;
        right: 1rem;
        top: 1.5rem;
    }

    .notification-empty {
        text-align: center;
        padding: 3rem 1rem;
        color: #9ca3af;
    }

    .notification-footer {
        padding: 0.75rem 1.25rem;
        border-top: 2px solid #e5e7eb;
        background: #f9fafb;
        border-radius: 0 0 15px 15px;
    }

    .notification-footer .btn-link {
        color: #3b82f6;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .notification-footer .btn-link:hover {
        text-decoration: underline;
    }

    /* Scrollbar styling */
    .notification-list::-webkit-scrollbar {
        width: 6px;
    }

    .notification-list::-webkit-scrollbar-track {
        background: #f3f4f6;
    }

    .notification-list::-webkit-scrollbar-thumb {
        background: #d1d5db;
        border-radius: 3px;
    }

    .notification-list::-webkit-scrollbar-thumb:hover {
        background: #9ca3af;
    }
</style>

<script>
    function markAsRead(event, notificationId) {
        // Prevent navigation until we mark read
        if (event) event.stopPropagation();
        
        fetch('/Student/MarkNotificationRead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ notificationId })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Update UI immediately
                const notificationItem = document.querySelector(`[data-id="${notificationId}"]`);
                if (notificationItem) {
                    notificationItem.classList.remove('unread');
                    notificationItem.classList.add('read');
                    
                    // Remove unread dot
                    const unreadDot = notificationItem.querySelector('.notification-unread-dot');
                    if (unreadDot) {
                        unreadDot.remove();
                    }
                    
                    // Update badge count
                    const unreadCount = document.querySelectorAll('.notification-item.unread').length;
                    const badge = document.querySelector('.notification-badge');
                    if (badge) {
                        if (unreadCount > 0) {
                            badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
                            badge.style.display = 'inline-block';
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                    
                    // Update mark all as read button visibility
                    if (unreadCount === 0) {
                        const markAllBtn = document.querySelector('.mark-all-read');
                        if (markAllBtn && markAllBtn.parentElement) {
                            markAllBtn.parentElement.remove();
                        }
                    }
                }
            }
        })
        .catch(error => console.error('Error marking notification as read:', error));
    }

    function markAllAsRead(event) {
        if (event) event.stopPropagation();
        fetch('/Student/MarkAllNotificationsRead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        }).then(() => location.reload());
    }
</script>

@functions {
    string GetNotificationIcon(NotificationType type)
    {
        return type switch
        {
            NotificationType.Achievement => "fas fa-trophy",
            NotificationType.LearningReminder => "fas fa-book",
            NotificationType.NewLesson => "fas fa-plus-circle",
            NotificationType.WeeklyReport => "fas fa-chart-line",
            _ => "fas fa-info-circle"
        };
    }

    string GetNotificationIconClass(NotificationType type)
    {
        return type switch
        {
            NotificationType.Achievement => "icon-achievement",
            NotificationType.LearningReminder => "icon-reminder",
            NotificationType.NewLesson => "icon-new",
            NotificationType.WeeklyReport => "icon-report",
            _ => "icon-system"
        };
    }

    string GetTimeAgo(DateTime date)
    {
        var timeSpan = DateTime.Now - date;
        if (timeSpan.TotalMinutes < 1) return "Vừa xong";
        if (timeSpan.TotalMinutes < 60) return $"{(int)timeSpan.TotalMinutes} phút trước";
        if (timeSpan.TotalHours < 24) return $"{(int)timeSpan.TotalHours} giờ trước";
        if (timeSpan.TotalDays < 7) return $"{(int)timeSpan.TotalDays} ngày trước";
        return date.ToString("dd/MM/yyyy HH:mm");
    }
}
