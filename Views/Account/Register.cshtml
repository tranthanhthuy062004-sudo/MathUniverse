@model MathUniverse.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary">
                        <i class="fas fa-user-plus"></i> Đăng ký tài khoản
                    </h2>
                    <p class="text-muted">Tham gia Vũ trụ Toán học cùng hàng ngàn học sinh khác!</p>
                </div>

                <form asp-controller="Account" asp-action="Register" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập họ và tên đầy đủ" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Grade" class="form-label"></label>
                            <select asp-for="Grade" class="form-select">
                                <option value="">-- Chọn lớp --</option>
                                <option value="1">Lớp 1</option>
                                <option value="2">Lớp 2</option>
                                <option value="3">Lớp 3</option>
                                <option value="4">Lớp 4</option>
                                <option value="5">Lớp 5</option>
                            </select>
                            <span asp-validation-for="Grade" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="DateOfBirth" class="form-label"></label>
                            <input asp-for="DateOfBirth" class="form-control" type="date" />
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ParentEmail" class="form-label"></label>
                        <input asp-for="ParentEmail" class="form-control" type="email" placeholder="email@example.com" />
                        <span asp-validation-for="ParentEmail" class="text-danger"></span>
                        <div class="form-text">
                            <i class="fas fa-info-circle"></i> Email phụ huynh để nhận báo cáo kết quả học tập
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-lightbulb"></i> 
                        <strong>Lưu ý:</strong> Sau khi đăng ký thành công, bạn sẽ nhận được <strong>mã học sinh</strong> 
                        để sử dụng cho các lần đăng nhập sau.
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-rocket"></i> Đăng ký
                        </button>
                    </div>

                    <div class="text-center">
                        <p class="mb-0">Đã có tài khoản? 
                            <a asp-controller="Account" asp-action="Login" class="text-primary fw-bold">
                                Đăng nhập ngay
                            </a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

