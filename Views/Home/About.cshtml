@{
    ViewData["Title"] = "Giới thiệu";
}

<style>
    /* Hero Section - Enhanced */
    .hero-about {
        background: linear-gradient(135deg, #e0e7ff 0%, #ddd6fe 50%, #fef3c7 100%);
        color: #0f172a;
        padding: 4.5rem 3.5rem;
        border-radius: 30px;
        margin-bottom: 3.5rem;
        box-shadow: 
            0 15px 50px rgba(139, 92, 246, 0.2),
            0 5px 20px rgba(245, 158, 11, 0.1);
        border: 2px solid rgba(139, 92, 246, 0.3);
    }
    
    .hero-about-title {
        font-size: 3.5rem;
        font-weight: 900;
        background: linear-gradient(135deg, #7c3aed 0%, #ec4899 50%, #f59e0b 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 3px 15px rgba(124, 58, 237, 0.3));
        letter-spacing: -1px;
    }
    
    .hero-about-subtitle {
        color: #1f2937;
        font-size: 1.35rem;
        font-weight: 700;
        line-height: 1.8;
        max-width: 820px;
        margin: 0 auto;
        text-shadow: 0 2px 8px rgba(255, 255, 255, 0.8);
    }
    
    /* Feature Cards - Enhanced */
    .feature-card-about {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(167, 139, 250, 0.05));
        border: 2px solid rgba(139, 92, 246, 0.3);
        border-radius: 24px;
        transition: all 0.3s ease;
        height: 100%;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(139, 92, 246, 0.12);
        animation: fadeUp 0.6s ease-out;
    }
    
    .feature-card-about:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 16px 40px rgba(139, 92, 246, 0.25);
        border-color: #8b5cf6;
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.12), rgba(167, 139, 250, 0.08));
    }
    
    .feature-card-about h3 {
        color: #7c3aed;
        font-weight: 900;
        font-size: 1.7rem;
        margin-bottom: 1rem;
        text-shadow: 0 2px 10px rgba(124, 58, 237, 0.15);
    }
    
    .feature-card-about p {
        color: #1f2937;
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1.9;
    }
    
    .feature-card-about p strong {
        color: #7c3aed;
        font-weight: 800;
    }
    
    .feature-card-about i {
        color: #f59e0b;
        font-size: 2.2rem;
        filter: drop-shadow(0 3px 10px rgba(245, 158, 11, 0.3));
    }
    
    /* Timeline - Enhanced */
    .timeline-section {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(245, 158, 11, 0.05));
        border: 2px solid rgba(139, 92, 246, 0.3);
        border-radius: 28px;
        padding: 3rem;
        margin-bottom: 3.5rem;
        box-shadow: 0 10px 30px rgba(139, 92, 246, 0.12);
    }
    
    .timeline-title {
        color: #7c3aed;
        font-weight: 900;
        font-size: 2.3rem;
        margin-bottom: 2.4rem;
        text-align: center;
        text-shadow: 0 2px 10px rgba(124, 58, 237, 0.15);
    }
    
    .timeline-item {
        position: relative;
        padding-left: 42px;
        padding-bottom: 28px;
        border-left: 4px solid #a78bfa;
        animation: fadeUp 0.6s ease-out;
    }
    
    .timeline-item::before {
        content: "";
        position: absolute;
        left: -14px;
        top: 0;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f59e0b, #fbbf24);
        box-shadow: 
            0 0 0 4px #a78bfa,
            0 3px 10px rgba(245, 158, 11, 0.5);
        border: 4px solid white;
        box-shadow: 0 0 0 4px #a78bfa;
    }
    
    .timeline-item:last-child {
        border-left: 4px solid transparent;
    }
    
    .timeline-item h5 {
        color: #7c3aed;
        font-weight: 900;
        font-size: 1.35rem;
        margin-bottom: 0.5rem;
        text-shadow: 0 1px 5px rgba(124, 58, 237, 0.1);
    }
    
    .timeline-item p {
        color: #1f2937;
        font-size: 1.1rem;
        font-weight: 600;
        line-height: 1.8;
    }
    
    /* Team Section - Enhanced */
    .team-section {
        margin-bottom: 3.5rem;
    }
    
    .team-title {
        color: #7c3aed;
        font-weight: 900;
        font-size: 2.3rem;
        margin-bottom: 2.4rem;
        text-align: center;
        text-shadow: 0 2px 10px rgba(124, 58, 237, 0.15);
    }
    
    .team-member {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(167, 139, 250, 0.05));
        border: 2px solid rgba(139, 92, 246, 0.3);
        text-align: center;
        padding: 2.5rem;
        border-radius: 26px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(139, 92, 246, 0.12);
    }
    
    .team-member:hover {
        transform: translateY(-8px);
        box-shadow: 0 16px 40px rgba(139, 92, 246, 0.25);
        border-color: #8b5cf6;
    }
    
    .team-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 50%, #f59e0b 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 3rem;
        color: white;
        box-shadow: 
            0 5px 20px rgba(139, 92, 246, 0.4),
            0 0 40px rgba(236, 72, 153, 0.2);
    }
    
    .team-member h5 {
        color: #7c3aed;
        font-weight: 900;
        font-size: 1.35rem;
        margin-bottom: 0.4rem;
        text-shadow: 0 1px 5px rgba(124, 58, 237, 0.1);
    }
    
    .team-member .text-primary {
        color: #8b5cf6 !important;
        font-weight: 700;
        font-size: 1.05rem;
    }
    
    .team-member .text-muted {
        color: #475569 !important;
        font-weight: 600;
    }
    
    /* Features Grid - Enhanced */
    .features-grid-title {
        color: #7c3aed;
        font-weight: 900;
        font-size: 2.3rem;
        margin-bottom: 2.4rem;
        text-align: center;
        text-shadow: 0 2px 10px rgba(124, 58, 237, 0.15);
    }
    
    .feature-box {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.08), rgba(167, 139, 250, 0.05));
        border: 2px solid rgba(139, 92, 246, 0.3);
        padding: 2.5rem 2rem;
        border-radius: 24px;
        text-align: center;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(139, 92, 246, 0.12);
        animation: fadeUp 0.6s ease-out;
    }
    
    .feature-box:hover {
        transform: translateY(-8px);
        box-shadow: 0 16px 40px rgba(139, 92, 246, 0.25);
        border-color: #8b5cf6;
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.12), rgba(167, 139, 250, 0.08));
    }
    
    .feature-box-icon {
        font-size: 3.8rem;
        margin-bottom: 1.2rem;
        color: #a78bfa;
        filter: drop-shadow(0 4px 15px rgba(167, 139, 250, 0.4));
    }
    
    .feature-box h5 {
        color: #7c3aed;
        font-weight: 900;
        font-size: 1.3rem;
        margin-bottom: 0.7rem;
        text-shadow: 0 1px 5px rgba(124, 58, 237, 0.1);
    }
    
    .feature-box p {
        color: #1f2937;
        font-size: 1.05rem;
        font-weight: 600;
        line-height: 1.7;
    }
    
    /* Call to Action - Enhanced */
    .cta-section {
        background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 50%, #f59e0b 100%);
        background-size: 200% 200%;
        animation: gradientShift 5s ease infinite;
        border: none;
        border-radius: 28px;
        padding: 4rem 3rem;
        text-align: center;
        box-shadow: 
            0 15px 50px rgba(139, 92, 246, 0.4),
            0 5px 20px rgba(236, 72, 153, 0.3);
    }
    
    @@keyframes gradientShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }
    
    .cta-title {
        color: white;
        font-weight: 900;
        font-size: 2.4rem;
        margin-bottom: 1.2rem;
        text-shadow: 0 3px 15px rgba(0, 0, 0, 0.2);
    }
    
    .cta-text {
        color: rgba(255, 255, 255, 0.95);
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 2rem;
        text-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
    
    .btn-cta {
        background: white;
        border: none;
        color: #7c3aed;
        font-weight: 900;
        padding: 1.2rem 3.5rem;
        border-radius: 999px;
        font-size: 1.15rem;
        box-shadow: 
            0 10px 35px rgba(255, 255, 255, 0.4),
            0 5px 15px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .btn-cta:hover {
        transform: translateY(-6px) scale(1.05);
        box-shadow: 
            0 15px 45px rgba(255, 255, 255, 0.5),
            0 8px 20px rgba(0, 0, 0, 0.15);
        color: #6d28d9;
        background: linear-gradient(135deg, #fbbf24, #f59e0b);
    }
    
    .btn-cta-outline {
        background: transparent;
        border: 3px solid white;
        color: white;
        font-weight: 800;
        padding: 1.1rem 3.3rem;
        border-radius: 999px;
        font-size: 1.1rem;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .btn-cta-outline:hover {
        background: white;
        color: #7c3aed;
        transform: translateY(-6px) scale(1.05);
        box-shadow: 
            0 15px 45px rgba(255, 255, 255, 0.4),
            0 8px 20px rgba(0, 0, 0, 0.15);
    }
    
    /* Keyframes */
    @@keyframes fadeUp {
        0% { opacity: 0; transform: translateY(18px); }
        100% { opacity: 1; transform: translateY(0); }
    }
    
    /* Responsive */
    @@media (max-width: 768px) {
        .hero-about-title {
            font-size: 2.4rem;
        }
        
        .hero-about-subtitle {
            font-size: 1.05rem;
        }
        
        .timeline-title,
        .team-title,
        .features-grid-title,
        .cta-title {
            font-size: 1.8rem;
        }
    }
</style>


<div class="container py-5">
    <!-- Hero Section -->
    <div class="hero-about text-center">
        <h1 class="hero-about-title">
            <i class="fas fa-rocket"></i> Chào mừng đến Vũ trụ Toán học!
        </h1>
        <p class="hero-about-subtitle">Học toán vui, dễ hiểu và tự tin mỗi ngày.</p>
    </div>

    <!-- What Students Will Learn -->
    <div class="row mb-5 g-4">
        <div class="col-md-6">
            <div class="feature-card-about">
                <h3>
                    <i class="fas fa-book-open"></i> Các em sẽ học gì?
                </h3>
                <p style="font-size: 1.1rem; line-height: 1.9;">
                    📚 <strong>Chương trình đầy đủ:</strong> Từ lớp 1 đến lớp 5<br>
                    🎯 <strong>Phù hợp trình độ:</strong> Bài học theo từng lớp<br>
                    🌱 <strong>Từ cơ bản đến nâng cao:</strong> Học theo lộ trình<br>
                    ✨ <strong>Toán trong cuộc sống:</strong> Ứng dụng thực tế
                </p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="feature-card-about">
                <h3>
                    <i class="fas fa-gift"></i> Các em nhận được gì?
                </h3>
                <p style="font-size: 1.1rem; line-height: 1.9;">
                    🌟 <strong>Video ngắn gọn:</strong> Dễ hiểu, sinh động<br>
                    🏅 <strong>Huy hiệu:</strong> Làm đúng được thưởng<br>
                    🎮 <strong>Bài tập tương tác:</strong> Vui như chơi game<br>
                    👥 <strong>Thi đua:</strong> So tài cùng bạn bè
                </p>
            </div>
        </div>
    </div>

    <!-- How It Works Timeline -->
    <div class="timeline-section">
        <h2 class="timeline-title">
            <i class="fas fa-map-marked-alt"></i> Học như thế nào nhỉ?
        </h2>
        <div class="timeline-item">
            <h5>Bước 1: Xem bài giảng 📺</h5>
            <p style="font-size: 1.02rem;">Xem video ngắn, dễ hiểu trước khi luyện tập.</p>
        </div>
        <div class="timeline-item">
            <h5>Bước 2: Luyện tập 🧩</h5>
            <p style="font-size: 1.02rem;">Làm bài tương tác, làm đúng có điểm và huy hiệu.</p>
        </div>
        <div class="timeline-item">
            <h5>Bước 3: Chơi trò chơi 🎮</h5>
            <p style="font-size: 1.02rem;">Trò chơi lật thẻ tìm cặp - vừa học vừa chơi, củng cố kiến thức một cách vui nhộn!</p>
        </div>
        <div class="timeline-item">
            <h5>Bước 4: Xem tiến bộ 🎯</h5>
            <p style="font-size: 1.02rem;">Theo dõi điểm và vị trí, mỗi ngày giỏi hơn.</p>
        </div>
    </div>

    <!-- Who Created This -->
    <div class="team-section">
        <h2 class="team-title">
            <i class="fas fa-users"></i> Ai tạo ra website này?
        </h2>
        <div class="row g-4 justify-content-center">
            <div class="col-md-8">
                <div class="team-member">
                    <div class="team-avatar" style="width: 140px; height: 140px; margin: 0 auto 1.6rem; font-size: 3.2rem;">
                        <i class="fas fa-graduation-cap"></i>
                    </div>
                    <h5 style="font-size: 1.4rem;">Các anh chị sinh viên</h5>
                    <p class="text-primary mb-3" style="font-size: 1.15rem;">Trường Đại học Giáo dục - ĐHQGHN</p>
                    <p class="text-muted" style="font-size: 1.02rem; line-height: 1.7;">
                        Giúp các em học toán vui hơn, tự tin hơn mỗi ngày.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Fun Features -->
    <div class="mb-5">
        <h2 class="features-grid-title">
            <i class="fas fa-star"></i> Vì sao học ở đây vui?
        </h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-box-icon">
                        <i class="fas fa-video" style="color: #a78bfa;"></i>
                    </div>
                    <h5>Video sinh động</h5>
                    <p style="font-size: 0.98rem;">Bài giảng ngắn gọn, rõ ràng, dễ hiểu.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-box-icon">
                        <i class="fas fa-gamepad" style="color: #a78bfa;"></i>
                    </div>
                    <h5>Bài tập như game</h5>
                    <p style="font-size: 0.98rem;">Trả lời, kéo thả, nối hình, ghi điểm dần dần.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-box-icon">
                        <i class="fas fa-trophy" style="color: #f59e0b;"></i>
                    </div>
                    <h5>Huy hiệu xinh</h5>
                    <p style="font-size: 0.98rem;">Làm đúng được thưởng, thu thập dần dần.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-box-icon">
                        <i class="fas fa-chart-line" style="color: #8b5cf6;"></i>
                    </div>
                    <h5>Thấy rõ tiến bộ</h5>
                    <p style="font-size: 0.98rem;">Điểm số và vị trí được cập nhật sau mỗi bài.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-box-icon">
                        <i class="fas fa-users" style="color: #a78bfa;"></i>
                    </div>
                    <h5>Thi đua bạn bè</h5>
                    <p style="font-size: 0.98rem;">Xem thứ hạng, thi đua nhẹ nhàng cùng lớp.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-box-icon">
                        <i class="fas fa-star" style="color: #f59e0b;"></i>
                    </div>
                    <h5>Bài học theo lớp</h5>
                    <p style="font-size: 0.98rem;">Từ lớp 1 đến 5, học đúng lớp nắm chắc.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Call to Action -->
    <div class="cta-section">
        <h3 class="cta-title">
            <i class="fas fa-rocket"></i> Sẵn sàng học toán vui chưa?
        </h3>
        <p class="cta-text">Khám phá bài học, luyện tập và nhận huy hiệu mỗi ngày.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Student" asp-action="Lessons" class="btn btn-cta">
                <i class="fas fa-play-circle"></i> Vào học ngay
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-cta me-3">
                <i class="fas fa-user-plus"></i> Đăng ký miễn phí
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-cta-outline">
                <i class="fas fa-sign-in-alt"></i> Đăng nhập
            </a>
        }
    </div>
</div>

