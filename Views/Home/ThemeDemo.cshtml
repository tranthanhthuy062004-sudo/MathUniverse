@{
    ViewData["Title"] = "Theme Demo";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">
            <i class="fas fa-palette"></i> Theme Demo
        </h1>
        <p class="lead">Màu sắc: Tím - Trắng - Vàng | Hỗ trợ Dark Mode</p>
        <p class="text-muted">Click nút 🌙/☀️ góc dưới phải để chuyển đổi chế độ</p>
    </div>

    <!-- Buttons -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Buttons</h5>
        </div>
        <div class="card-body">
            <button class="btn btn-primary me-2 mb-2">Primary (Tím)</button>
            <button class="btn btn-outline-primary me-2 mb-2">Outline Primary</button>
            <button class="btn btn-success me-2 mb-2">Success (Vàng)</button>
            <button class="btn btn-warning me-2 mb-2">Warning (Vàng)</button>
            <button class="btn btn-secondary me-2 mb-2">Secondary</button>
            <button class="btn btn-info me-2 mb-2">Info</button>
        </div>
    </div>

    <!-- Badges -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Badges</h5>
        </div>
        <div class="card-body">
            <span class="badge bg-primary me-2 mb-2">Lớp 1</span>
            <span class="badge bg-primary me-2 mb-2">Lớp 2</span>
            <span class="badge bg-warning me-2 mb-2">Mới</span>
            <span class="badge bg-success me-2 mb-2">Hoàn thành</span>
            <span class="badge bg-info me-2 mb-2">Đang học</span>
            <span class="badge bg-secondary me-2 mb-2">Chưa mở</span>
        </div>
    </div>

    <!-- Cards -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card h-100 bg-primary text-white">
                <div class="card-body">
                    <div class="display-4 mb-3"><i class="fas fa-book"></i></div>
                    <h5>Bài học</h5>
                    <h2>125</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100 bg-success text-white">
                <div class="card-body">
                    <div class="display-4 mb-3"><i class="fas fa-check"></i></div>
                    <h5>Hoàn thành</h5>
                    <h2>89</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card h-100 bg-warning text-dark">
                <div class="card-body">
                    <div class="display-4 mb-3"><i class="fas fa-star"></i></div>
                    <h5>Điểm TB</h5>
                    <h2>8.5</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Progress Bars -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Progress Bars</h5>
        </div>
        <div class="card-body">
            <div class="mb-3">
                <label>Tiến độ học tập (75%)</label>
                <div class="progress" style="height: 25px;">
                    <div class="progress-bar" style="width: 75%">75%</div>
                </div>
            </div>
            <div class="mb-3">
                <label>Bài tập hoàn thành (50%)</label>
                <div class="progress" style="height: 25px;">
                    <div class="progress-bar bg-success" style="width: 50%">50%</div>
                </div>
            </div>
            <div class="mb-3">
                <label>Điểm đạt được (90%)</label>
                <div class="progress" style="height: 25px;">
                    <div class="progress-bar bg-warning" style="width: 90%">90%</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Forms -->
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Form Elements</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Họ và tên</label>
                    <input type="text" class="form-control" placeholder="Nhập họ tên">
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Lớp</label>
                    <select class="form-select">
                        <option>Chọn lớp</option>
                        <option>Lớp 1</option>
                        <option>Lớp 2</option>
                        <option>Lớp 3</option>
                        <option>Lớp 4</option>
                        <option>Lớp 5</option>
                    </select>
                </div>
                <div class="col-12 mb-3">
                    <label class="form-label">Ghi chú</label>
                    <textarea class="form-control" rows="3" placeholder="Nhập ghi chú"></textarea>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="check1">
                        <label class="form-check-label" for="check1">
                            Tôi đồng ý với điều khoản sử dụng
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Alerts -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Alerts</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-success alert-dismissible fade show">
                <i class="fas fa-check-circle"></i> <strong>Thành công!</strong> Bài tập đã được hoàn thành.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <div class="alert alert-info alert-dismissible fade show">
                <i class="fas fa-info-circle"></i> <strong>Thông tin:</strong> Có 3 bài học mới được cập nhật.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <div class="alert alert-warning alert-dismissible fade show">
                <i class="fas fa-exclamation-triangle"></i> <strong>Cảnh báo:</strong> Bạn cần hoàn thành bài trước.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    </div>

    <!-- Gradient Backgrounds -->
    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="card bg-gradient text-dark p-4 text-center">
                <h4>Purple-Yellow Gradient</h4>
                <p class="mb-0">Gradient nhẹ nhàng</p>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="card bg-gradient-primary text-white p-4 text-center">
                <h4>Purple Gradient</h4>
                <p class="mb-0">Gradient đậm</p>
            </div>
        </div>
    </div>

    <!-- Typography -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Typography</h5>
        </div>
        <div class="card-body">
            <h1 class="text-primary">Heading 1 - Tím</h1>
            <h2 class="text-dark">Heading 2 - Dark</h2>
            <h3>Heading 3 - Default</h3>
            <p class="lead">Lead paragraph - Đoạn văn nổi bật</p>
            <p>Normal paragraph - Đoạn văn bình thường với <a href="#">link màu tím</a></p>
            <p class="text-muted">Muted text - Text phụ</p>
            <p class="text-primary">Primary text - Text tím</p>
        </div>
    </div>

    <!-- Icon Examples -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Icons với Theme Colors</h5>
        </div>
        <div class="card-body text-center">
            <i class="fas fa-rocket fa-3x text-primary me-3"></i>
            <i class="fas fa-star fa-3x text-warning me-3"></i>
            <i class="fas fa-graduation-cap fa-3x text-primary me-3"></i>
            <i class="fas fa-trophy fa-3x text-warning me-3"></i>
            <i class="fas fa-book-open fa-3x text-primary me-3"></i>
            <i class="fas fa-certificate fa-3x text-warning me-3"></i>
        </div>
    </div>
</div>

