@model MathUniverse.Models.ExerciseResult
@{
    ViewData["Title"] = "Chi tiết bài làm";
    var hasEssayQuestions = Model.Exercise.Questions.Any(q => q.Type == MathUniverse.Models.QuestionType.Essay);
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-file-alt"></i> Chi tiết bài làm</h2>
        <a asp-action="StudentDetail" asp-route-id="@Model.StudentId" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Student & Exercise Info -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-user-graduate"></i> Thông tin học sinh</h5>
                </div>
                <div class="card-body">
                    <p><strong>Họ tên:</strong> @Model.Student.FullName</p>
                    <p><strong>Mã học sinh:</strong> @Model.Student.StudentCode</p>
                    <p><strong>Lớp:</strong> @Model.Student.Grade</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-tasks"></i> Thông tin bài tập</h5>
                </div>
                <div class="card-body">
                    <p><strong>Bài học:</strong> @Model.Exercise.Lesson.Title</p>
                    <p><strong>Bài tập:</strong> @Model.Exercise.Title</p>
                    <p><strong>Ngày làm:</strong> @Model.CompletedDate.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Thời gian làm:</strong> @Model.TimeSpent giây</p>
                    <p><strong>Lần thử:</strong> @Model.AttemptNumber</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Score Summary -->
    <div class="card shadow-sm mb-4">
        <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <h5 class="mb-0 text-white"><i class="fas fa-chart-bar"></i> Kết quả</h5>
        </div>
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-3">
                    <h3>
                        @if (Model.GradingStatus == MathUniverse.Models.GradingStatus.PendingGrading)
                        {
                            <span class="badge bg-warning text-dark" style="font-size: 1.5rem;">Đang chờ chấm</span>
                        }
                        else
                        {
                            <span class="badge @(Model.IsPassed ? "bg-success" : "bg-danger")" style="font-size: 1.5rem;">
                                @Model.Score.ToString("F1")/10
                            </span>
                        }
                    </h3>
                    <p class="text-muted">Điểm số</p>
                </div>
                <div class="col-md-3">
                    <h3 class="text-primary">@Model.CorrectAnswers/@Model.TotalQuestions</h3>
                    <p class="text-muted">Câu đúng (Trắc nghiệm)</p>
                </div>
                <div class="col-md-3">
                    <h3>
                        @if (Model.GradingStatus == MathUniverse.Models.GradingStatus.PendingGrading)
                        {
                            <span class="badge bg-warning text-dark"><i class="fas fa-clock"></i> Chờ chấm</span>
                        }
                        else if (Model.IsPassed)
                        {
                            <span class="badge bg-success"><i class="fas fa-check-circle"></i> Đạt</span>
                        }
                        else
                        {
                            <span class="badge bg-danger"><i class="fas fa-times-circle"></i> Chưa đạt</span>
                        }
                    </h3>
                    <p class="text-muted">Trạng thái</p>
                </div>
                <div class="col-md-3">
                    <h3 class="text-info">@Model.Exercise.PassingScore.ToString("F1")</h3>
                    <p class="text-muted">Điểm đạt yêu cầu</p>
                </div>
            </div>
        </div>
    </div>

    @if (hasEssayQuestions)
    {
        <!-- Essay Answers -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="fas fa-pen-square"></i> Câu hỏi tự luận</h5>
            </div>
            <div class="card-body">
                @if (Model.EssayAnswers.Any())
                {
                    @foreach (var essayAnswer in Model.EssayAnswers.OrderBy(ea => ea.Question.OrderIndex))
                    {
                        <div class="card mb-3 @(essayAnswer.Score.HasValue ? "border-success" : "border-warning")">
                            <div class="card-header @(essayAnswer.Score.HasValue ? "bg-light" : "bg-warning bg-opacity-10")">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1"><strong>Câu @essayAnswer.Question.OrderIndex:</strong> @essayAnswer.Question.QuestionText</h6>
                                        @if (!string.IsNullOrEmpty(essayAnswer.Question.ImageUrl))
                                        {
                                            <img src="@essayAnswer.Question.ImageUrl" class="img-fluid mt-2" style="max-width: 400px;" alt="Question Image" />
                                        }
                                    </div>
                                    @if (essayAnswer.Score.HasValue)
                                    {
                                        <span class="badge bg-success" style="font-size: 1rem;">@essayAnswer.Score.Value.ToString("F1")/10</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Chưa chấm</span>
                                    }
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <strong class="text-primary">Câu trả lời của học sinh:</strong>
                                    <p class="mt-2">@essayAnswer.AnswerText</p>
                                    @if (!string.IsNullOrEmpty(essayAnswer.ImageUrl))
                                    {
                                        <div class="mt-2">
                                            <img src="@essayAnswer.ImageUrl" class="img-fluid border rounded" style="max-width: 600px; cursor: pointer;" 
                                                 alt="Student Answer" onclick="window.open('@essayAnswer.ImageUrl', '_blank')" />
                                            <p class="text-muted small">Click vào ảnh để xem full size</p>
                                        </div>
                                    }
                                </div>

                                @if (essayAnswer.Score.HasValue)
                                {
                                    <!-- Already Graded -->
                                    <div class="alert alert-success mb-0">
                                        <strong><i class="fas fa-check-circle"></i> Đã chấm điểm:</strong> @essayAnswer.Score.Value.ToString("F1")/10
                                        @if (!string.IsNullOrEmpty(essayAnswer.Feedback))
                                        {
                                            <p class="mb-0 mt-2"><strong>Nhận xét:</strong> @essayAnswer.Feedback</p>
                                        }
                                        <p class="mb-0 mt-1 text-muted small">Chấm lúc: @essayAnswer.GradedDate?.ToString("dd/MM/yyyy HH:mm")</p>
                                    </div>
                                }
                                else
                                {
                                    <!-- Grading Form -->
                                    <div class="border-top pt-3">
                                        <form class="essay-grading-form" data-essay-id="@essayAnswer.EssayAnswerId">
                                            <div class="row">
                                                <div class="col-md-3">
                                                    <label class="form-label"><strong>Điểm (0-10):</strong></label>
                                                    <input type="number" class="form-control" name="score" min="0" max="10" step="0.5" required />
                                                </div>
                                                <div class="col-md-7">
                                                    <label class="form-label"><strong>Nhận xét:</strong></label>
                                                    <textarea class="form-control" name="feedback" rows="2" placeholder="Nhập nhận xét cho học sinh (không bắt buộc)"></textarea>
                                                </div>
                                                <div class="col-md-2 d-flex align-items-end">
                                                    <button type="submit" class="btn btn-primary w-100">
                                                        <i class="fas fa-check"></i> Chấm điểm
                                                    </button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted">Không có câu trả lời tự luận.</p>
                }
            </div>
        </div>
    }

    <!-- Multiple Choice Answers (if any) -->
    @if (Model.Exercise.Questions.Any(q => q.Type == MathUniverse.Models.QuestionType.MultipleChoice))
    {
        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="fas fa-list-check"></i> Câu hỏi trắc nghiệm</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Điểm trắc nghiệm đã được tính tự động khi học sinh nộp bài.</p>
                <p><strong>Số câu đúng:</strong> @Model.CorrectAnswers/@Model.TotalQuestions</p>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.essay-grading-form').on('submit', function(e) {
                e.preventDefault();
                
                const form = $(this);
                const essayId = form.data('essay-id');
                const score = parseFloat(form.find('input[name="score"]').val());
                const feedback = form.find('textarea[name="feedback"]').val();
                
                if (score < 0 || score > 10) {
                    alert('Điểm phải từ 0 đến 10');
                    return;
                }
                
                if (!confirm(`Bạn có chắc chắn muốn chấm ${score} điểm cho câu này?`)) {
                    return;
                }
                
                const submitBtn = form.find('button[type="submit"]');
                submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Đang chấm...');
                
                $.post('@Url.Action("GradeEssay", "Admin")', {
                    essayAnswerId: essayId,
                    score: score,
                    feedback: feedback
                })
                .done(function(response) {
                    if (response.success) {
                        // Reload page to show updated scores
                        location.reload();
                    } else {
                        alert('Lỗi: ' + response.message);
                        submitBtn.prop('disabled', false).html('<i class="fas fa-check"></i> Chấm điểm');
                    }
                })
                .fail(function() {
                    alert('Không thể kết nối đến server!');
                    submitBtn.prop('disabled', false).html('<i class="fas fa-check"></i> Chấm điểm');
                });
            });
        });
    </script>
}

