@model List<MathUniverse.Models.Notification>
@{
    ViewData["Title"] = "Thông báo";
}

<div class="notifications-page">
    <div class="container py-4">
        <div class="page-header mb-4">
            <h2 class="fw-bold">
                <i class="fas fa-bell text-primary"></i> Thông báo của bạn
            </h2>
            <p class="text-muted">Xem tất cả thông báo và cập nhật mới nhất</p>
        </div>

        @if (Model.Any())
        {
            <div class="row">
                <div class="col-md-8 mx-auto">
                    @foreach (var notification in Model)
                    {
                        <div class="notification-card @(!notification.IsRead ? "unread" : "")" data-id="@notification.NotificationId">
                            <div class="notification-icon-large @GetNotificationIconClass(notification.Type)">
                                <i class="@GetNotificationIcon(notification.Type)"></i>
                            </div>
                            <div class="notification-body">
                                <div class="notification-header-full">
                                    <h5 class="notification-title-full">@notification.Title</h5>
                                    <div class="notification-time-full">
                                        <i class="far fa-clock"></i> @GetTimeAgo(notification.CreatedDate)
                                    </div>
                                </div>
                                <p class="notification-message-full">@notification.Message</p>
                                @if (!string.IsNullOrEmpty(notification.LinkUrl))
                                {
                                    <a href="@notification.LinkUrl" class="btn btn-sm btn-primary">
                                        <i class="fas fa-arrow-right"></i> Xem chi tiết
                                    </a>
                                }
                            </div>
                            @if (!notification.IsRead)
                            {
                                <button class="btn btn-sm btn-outline-success mark-read-btn" onclick="markAsRead(@notification.NotificationId)">
                                    <i class="fas fa-check"></i> Đánh dấu đã đọc
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fas fa-inbox fa-5x text-muted mb-4"></i>
                <h4>Chưa có thông báo nào</h4>
                <p class="text-muted">Bạn sẽ nhận được thông báo khi có hoạt động mới</p>
                <a asp-action="Dashboard" class="btn btn-primary mt-3">
                    <i class="fas fa-home"></i> Về trang chủ
                </a>
            </div>
        }
    </div>
</div>

@functions {
    string GetNotificationIcon(NotificationType type)
    {
        return type switch
        {
            NotificationType.Achievement => "fas fa-trophy",
            NotificationType.LearningReminder => "fas fa-book",
            NotificationType.NewLesson => "fas fa-plus-circle",
            NotificationType.WeeklyReport => "fas fa-chart-line",
            _ => "fas fa-info-circle"
        };
    }

    string GetNotificationIconClass(NotificationType type)
    {
        return type switch
        {
            NotificationType.Achievement => "icon-achievement",
            NotificationType.LearningReminder => "icon-reminder",
            NotificationType.NewLesson => "icon-new",
            NotificationType.WeeklyReport => "icon-report",
            _ => "icon-system"
        };
    }

    string GetTimeAgo(DateTime date)
    {
        var timeSpan = DateTime.Now - date;
        
        if (timeSpan.TotalMinutes < 1)
            return "Vừa xong";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes} phút trước";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours} giờ trước";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays} ngày trước";
        
        return date.ToString("dd/MM/yyyy HH:mm");
    }
}

<style>
    .notifications-page {
        background: linear-gradient(180deg, #f0f9ff 0%, #e0e7ff 50%, #fce7f3 100%);
        min-height: 100vh;
    }

    .page-header {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(99, 102, 241, 0.1) 100%);
        padding: 2rem;
        border-radius: 20px;
        border: 2px solid rgba(59, 130, 246, 0.2);
    }

    .notification-card {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        display: flex;
        align-items: start;
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

    .notification-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
        border-color: #3b82f6;
    }

    .notification-card.unread {
        background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 100%);
        border-color: #3b82f6;
    }

    .notification-icon-large {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 1.5rem;
        flex-shrink: 0;
        font-size: 1.5rem;
    }

    .icon-achievement {
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: #fff;
    }

    .icon-reminder {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: #fff;
    }

    .icon-new {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: #fff;
    }

    .icon-report {
        background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
        color: #fff;
    }

    .icon-system {
        background: linear-gradient(135deg, #6b7280 0%, #4b5563 100%);
        color: #fff;
    }

    .notification-body {
        flex: 1;
    }

    .notification-header-full {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 0.5rem;
    }

    .notification-title-full {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1f2937;
        margin: 0;
    }

    .notification-time-full {
        font-size: 0.875rem;
        color: #9ca3af;
        white-space: nowrap;
        margin-left: 1rem;
    }

    .notification-message-full {
        color: #6b7280;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1rem;
    }

    .mark-read-btn {
        margin-left: 1rem;
        flex-shrink: 0;
    }

    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: #6b7280;
    }

    .empty-state i {
        opacity: 0.3;
    }
</style>

<script>
    function markAsRead(notificationId) {
        fetch('/Student/MarkNotificationRead', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ notificationId: notificationId })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                const card = document.querySelector(`[data-id="${notificationId}"]`);
                if (card) {
                    card.classList.remove('unread');
                    const btn = card.querySelector('.mark-read-btn');
                    if (btn) btn.remove();
                }
            }
        })
        .catch(error => console.error('Error marking notification as read:', error));
    }
</script>

