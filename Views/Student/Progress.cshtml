@using MathUniverse.Models
@model List<MathUniverse.Models.ViewModels.LessonProgressViewModel>
@{
    ViewData["Title"] = "Chi tiết tiến độ";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="fw-bold">
            <i class="fas fa-chart-line text-primary"></i> Chi tiết tiến độ học tập
        </h2>
        <a asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại Bảng điều khiển
        </a>
    </div>
    <p class="text-muted">Theo dõi tiến độ học tập của bạn qua từng bài học</p>
</div>

<!-- Grade Tabs - Đồng bộ thiết kế -->
<div class="grade-tabs-container mb-5">
    <div class="grade-tabs">
        <a asp-action="Progress" class="grade-tab @(ViewBag.SelectedGrade == null ? "active" : "")">
            <i class="fas fa-th-large"></i>
            <span class="grade-label">Tất cả</span>
        </a>
        @for (int i = 1; i <= 5; i++)
        {
            var icons = new[] { "fa-dice-one", "fa-dice-two", "fa-dice-three", "fa-dice-four", "fa-dice-five" };
            var colors = new[] { "grade-1", "grade-2", "grade-3", "grade-4", "grade-5" };
            <a asp-action="Progress" asp-route-grade="@i" class="grade-tab @colors[i-1] @(ViewBag.SelectedGrade == i ? "active" : "")">
                <i class="fas @icons[i-1]"></i>
                <span class="grade-label">Lớp @i</span>
            </a>
        }
    </div>
</div>

<!-- Thống kê tổng quan -->
<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="card border-success">
            <div class="card-body text-center">
                <div class="display-4 text-success mb-2">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h5 class="card-title">@Model.Count(p => p.Status == ProgressStatus.Passed)</h5>
                <p class="card-text text-muted">Hoàn thành</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-warning">
            <div class="card-body text-center">
                <div class="display-4 text-warning mb-2">
                    <i class="fas fa-spinner"></i>
                </div>
                <h5 class="card-title">@Model.Count(p => p.Status == ProgressStatus.InProgress)</h5>
                <p class="card-text text-muted">Đang học</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-info">
            <div class="card-body text-center">
                <div class="display-4 text-info mb-2">
                    <i class="fas fa-book"></i>
                </div>
                <h5 class="card-title">@Model.Count(p => p.Status == ProgressStatus.NotStarted)</h5>
                <p class="card-text text-muted">Chưa học</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card border-primary">
            <div class="card-body text-center">
                <div class="display-4 text-primary mb-2">
                    <i class="fas fa-percentage"></i>
                </div>
                <h5 class="card-title">@(Model.Any() ? Model.Average(p => p.CompletionPercentage).ToString("F1") : "0")%</h5>
                <p class="card-text text-muted">Tiến độ trung bình</p>
            </div>
        </div>
    </div>
</div>

<!-- Danh sách bài học -->
<div class="card shadow-sm border-0">
    <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none;">
        <h5 class="mb-0" style="color: #ffffff;">
            <i class="fas fa-list"></i> Danh sách bài học
        </h5>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Bài học</th>
                            <th>Chủ đề</th>
                            <th>Trạng thái</th>
                            <th>Tiến độ</th>
                            <th>Ngày hoàn thành</th>
                            <th>Bài tập</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var progress in Model.OrderBy(p => p.LessonId))
                        {
                            <tr class="@(progress.Status == ProgressStatus.Passed ? "table-success" : "")">
                                <td>
                                    <strong>@progress.Title</strong>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@progress.Topic</span>
                                </td>
                                <td>
                                    @if (progress.Status == ProgressStatus.Passed)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle"></i> Hoàn thành
                                        </span>
                                    }
                                    else if (progress.Status == ProgressStatus.InProgress)
                                    {
                                        <span class="badge bg-warning">
                                            <i class="fas fa-clock"></i> Đang học
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="fas fa-circle"></i> Chưa học
                                        </span>
                                    }
                                </td>
                                <td style="width: 200px;">
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1 me-2" style="height: 20px;">
                                            <div class="progress-bar @(progress.Status == ProgressStatus.Passed ? "bg-success" : "bg-warning")" 
                                                 role="progressbar" 
                                                 style="width: @(progress.CompletionPercentage)%"
                                                 aria-valuenow="@progress.CompletionPercentage" 
                                                 aria-valuemin="0" 
                                                 aria-valuemax="100">
                                                @progress.CompletionPercentage.ToString("F0")%
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (progress.CompletedDate.HasValue)
                                    {
                                        <small class="text-muted">
                                            <i class="fas fa-calendar"></i> @progress.CompletedDate.Value.ToString("dd/MM/yyyy")
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="LessonDetail" asp-route-id="@progress.LessonId" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i> Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="fas fa-book-open fa-3x mb-3"></i>
                <p>Chưa có dữ liệu tiến độ học tập.</p>
                <a asp-action="Lessons" class="btn btn-primary">
                    <i class="fas fa-play"></i> Bắt đầu học ngay
                </a>
            </div>
        }
    </div>
</div>

<!-- Chart visualization (optional - có thể thêm sau) -->
<div class="card shadow-sm mt-4 border-0">
    <div class="card-header" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none;">
        <h5 class="mb-0" style="color: #ffffff;">
            <i class="fas fa-chart-pie"></i> Biểu đồ tiến độ
        </h5>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <canvas id="statusChart" height="200"></canvas>
            </div>
            <div class="col-md-6">
                <canvas id="progressChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Status Chart
        const statusCtx = document.getElementById('statusChart').getContext('2d');
        const statusChart = new Chart(statusCtx, {
            type: 'doughnut',
            data: {
                labels: ['Hoàn thành', 'Đang học', 'Chưa học'],
                datasets: [{
                    data: [
                        @Model.Count(p => p.Status == ProgressStatus.Passed),
                        @Model.Count(p => p.Status == ProgressStatus.InProgress),
                        @Model.Count(p => p.Status == ProgressStatus.NotStarted)
                    ],
                    backgroundColor: ['#10b981', '#f59e0b', '#6b7280']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    },
                    title: {
                        display: true,
                        text: 'Trạng thái học tập'
                    }
                }
            }
        });

        // Progress Chart
        const progressCtx = document.getElementById('progressChart').getContext('2d');
        const progressChart = new Chart(progressCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Take(10).Select(p => p.Title).ToList())),
                datasets: [{
                    label: 'Tiến độ (%)',
                    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Take(10).Select(p => p.CompletionPercentage).ToList())),
                    backgroundColor: '#8b5cf6'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 100
                    }
                },
                plugins: {
                    legend: {
                        display: false
                    },
                    title: {
                        display: true,
                        text: 'Tiến độ 10 bài học gần nhất'
                    }
                }
            }
        });
    </script>
}

