@model List<MathUniverse.Models.ViewModels.LessonViewModel>
@{
    ViewData["Title"] = "Danh sách bài học";
    var selectedGrade = ViewBag.SelectedGrade ?? ViewBag.StudentGrade;
}

<div class="mb-4">
    <h2 class="fw-bold">
        <i class="fas fa-book text-primary"></i> Danh sách bài học
    </h2>
    <p class="text-muted">
        @if (selectedGrade == ViewBag.StudentGrade)
        {
            <span>Bài học lớp @selectedGrade dành cho bạn</span>
        }
        else
        {
            <span>Bài học lớp @selectedGrade (Bạn đang học lớp @ViewBag.StudentGrade - các bài này đang khóa)</span>
        }
    </p>
</div>

<!-- Grade Tabs - Đồng bộ thiết kế -->
<div class="grade-tabs-container mb-5">
    <div class="grade-tabs">
        @for (int i = 1; i <= 5; i++)
        {
            var icons = new[] { "fa-dice-one", "fa-dice-two", "fa-dice-three", "fa-dice-four", "fa-dice-five" };
            var colors = new[] { "grade-1", "grade-2", "grade-3", "grade-4", "grade-5" };
            var isCurrentGrade = (i == ViewBag.StudentGrade);
            <a asp-action="Lessons" asp-route-grade="@i" 
               class="grade-tab @colors[i-1] @(selectedGrade == i ? "active" : "") @(isCurrentGrade ? "" : "opacity-75")"
               title="@(isCurrentGrade ? "Lớp của bạn" : "Xem trước - Bài học đang khóa")">
                <i class="fas @icons[i-1]"></i>
                <span class="grade-label">Lớp @i</span>
                @if (isCurrentGrade)
                {
                    <i class="fas fa-star text-warning ms-1" style="font-size: 0.7rem;" title="Lớp hiện tại"></i>
                }
                else
                {
                    <i class="fas fa-lock ms-1" style="font-size: 0.7rem;" title="Đang khóa"></i>
                }
            </a>
        }
    </div>
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var lesson in Model)
        {
            var isWrongGrade = (lesson.Grade != ViewBag.StudentGrade);
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm @(!lesson.IsUnlocked ? "opacity-50" : "")">
                    @if (!string.IsNullOrEmpty(lesson.ThumbnailUrl))
                    {
                        <img src="@lesson.ThumbnailUrl" class="card-img-top" alt="@lesson.Title" style="height: 200px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="card-img-top bg-gradient-primary d-flex align-items-center justify-content-center" style="height: 200px;">
                            @if (isWrongGrade)
                            {
                                <i class="fas fa-lock text-white" style="font-size: 4rem; opacity: 0.7;"></i>
                            }
                            else
                            {
                                <i class="fas fa-book-open text-white" style="font-size: 4rem;"></i>
                            }
                        </div>
                    }
                    <div class="card-body">
                        <div class="mb-2">
                            <span class="badge bg-primary">Lớp @lesson.Grade</span>
                            <span class="badge bg-secondary">@lesson.Topic</span>
                            @if (lesson.Status == MathUniverse.Models.ProgressStatus.Passed)
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-check"></i> Hoàn thành
                                </span>
                            }
                            else if (isWrongGrade)
                            {
                                <span class="badge bg-danger">
                                    <i class="fas fa-lock"></i> Lớp khác
                                </span>
                            }
                            else if (!lesson.IsUnlocked)
                            {
                                <span class="badge bg-warning">
                                    <i class="fas fa-lock"></i> Chưa mở khóa
                                </span>
                            }
                        </div>
                        <h5 class="card-title">@lesson.Title</h5>
                        <p class="card-text text-muted small">@lesson.Description</p>
                        
                        @if (lesson.CompletionPercentage > 0 && lesson.CompletionPercentage < 100)
                        {
                            <div class="progress mb-3" style="height: 8px;">
                                <div class="progress-bar" role="progressbar" 
                                     style="width: @(lesson.CompletionPercentage)%" 
                                     aria-valuenow="@lesson.CompletionPercentage" 
                                     aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <small class="text-muted">Tiến độ: @string.Format("{0:F0}", lesson.CompletionPercentage)%</small>
                        }
                        
                        <div class="mt-3">
                            @if (isWrongGrade)
                            {
                                <button class="btn btn-danger w-100" disabled title="Bạn cần học đúng lớp của mình">
                                    <i class="fas fa-ban"></i> Chưa đến lớp này
                                </button>
                            }
                            else if (lesson.IsUnlocked)
                            {
                                <a asp-controller="Student" asp-action="LessonDetail" asp-route-id="@lesson.LessonId" 
                                   class="btn btn-primary w-100">
                                    <i class="fas fa-play-circle"></i> 
                                    @(lesson.Status == MathUniverse.Models.ProgressStatus.Passed ? "Ôn tập" : 
                                      lesson.Status == MathUniverse.Models.ProgressStatus.InProgress ? "Tiếp tục học" : "Bắt đầu học")
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary w-100" disabled>
                                    <i class="fas fa-lock"></i> Chưa mở khóa
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
        <h4>Chưa có bài học nào</h4>
        <p class="text-muted">Các bài học sẽ sớm được cập nhật</p>
    </div>
}

